{
  "name": "next-pls",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check . --verbose",
    "format": "biome check --write --unsafe .",
    "biome:ci": "biome ci .",
    "codegen:contentful": "graphql-codegen --config config/codegen.contentful.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@contentful/rich-text-react-renderer": "^16.1.6",
    "@contentful/rich-text-types": "^17.2.5",
    "clsx": "^2.1.1",
    "graphql": "^16.13.1",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/typed-document-node": "^6.1.7",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "contentful-cli": "^3.10.4",
    "contentful-management": "^11.74.0",
    "dotenv": "^17.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts,json,jsonc,css}": [
      "biome check --write --unsafe"
    ]
  },
  "browserslist": {
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "production": [
      "defaults",
      "not dead",
      "not op_mini all"
    ]
  }
}
